# Helius
HELIUS_API_KEY=your_helius_api_key
HELIUS_WEBHOOK_URL=https://your-railway-url.up.railway.app/webhook
HELIUS_WEBHOOK_ID=                        # vide au départ, remplis après /setup
HELIUS_WEBHOOK_SECRET=optional_secret

# Wallets to track (comma separated, no spaces)
WATCHED_WALLETS=ADDRESS1,ADDRESS2

# Minimum SOL to start/extend a chain
MIN_SOL_THRESHOLD=0.5

# Telegram
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=6368036558

# TradeWiz format: mint_only | BUY | SNIPE
TRADEWIZ_FORMAT=mint_only

# Logging: debug | info | warn | error
LOG_LEVEL=info

# Setup endpoint security
SETUP_SECRET=a_strong_password
